NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/devclash
JWT_SECRET=devclash-local-secret
JWT_EXPIRES_IN=7d

# OpenAI-compatible LLM endpoint for Epic 0 planner/practice/test generation
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=stepfun/step-3.5-flash:free
LLM_TIMEOUT_MS=45000
LLM_APP_NAME=DevClash AI Retention
LLM_SITE_URL=
LLM_REASONING_ENABLED=true
# Leave empty for auto mode. Set true/false to force behavior.
LLM_FORCE_JSON_MODE=

# Optional Redis queue backend (falls back to in-memory mode when unavailable)
REDIS_URL=

# API throttling
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
